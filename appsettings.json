{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Common": {
    "SensorDataMigrationBatchSize": 100000,
    "ImportEntitiesExecutionIntervalInSeconds": 3600,
    "SensorDataMigrationExecutionIntervalInSeconds": 300
  },
  "HomeAssistant": {
    "Uri": "ws://YourHA_IP/api/websocket",
    "Token": "HA Secret Token"
  },
  "Postgres": {
    "Host": "Your IP of the Postgres DB with HA data",
    "Port": 5432,
    "Username": "SuperUser",
    "Password": "SuperUserPassword",
    "Database": "HA Database Name"
  },
  "ClickHouse": {
    "Host": "Your IP of the ClickHouse DB",
    "Port": 8123,
    "Username": "SuperClickHouseUser",
    "Password": "SuperClickHouseUserPassword",
    "Database": "ClickHouseDatabase"
  }
}
